# =============================================================================
# Copy to .env.local and fill in values. Never commit real secrets.
# =============================================================================

# Public site URL (used by Stripe redirect URLs). No trailing slash.
# Example: http://localhost:3000  or  https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Booksy public profile (used for reviews link/embed).
NEXT_PUBLIC_BOOKSY_URL=https://booksy.com/en-gb/99970_elen-makeup-telford_skin-care_1255315_donnington#ba_s=sr_1

# Google Reviews (server-side via Places API).
# Enable "Places API" in Google Cloud and create an API key.
GOOGLE_PLACES_API_KEY=
# Your business Place ID (used by Places Details API).
GOOGLE_PLACE_ID=

# Admin allowlist (comma-separated emails). Only these users can access `/admin`.
ADMIN_EMAILS=

# Supabase (browser + server). Create a project at https://supabase.com
# Required for real data; if unset, the app uses build-time placeholders (API calls will fail until configured).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Postgres connection string (server-only).
# Replace [YOUR-PASSWORD] with your database password from Supabase.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.kdmqvegdbvuymoegzftm.supabase.co:5432/postgres

# Server-only: bypasses RLS. Use in API routes / webhooks only.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (payments). Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Supabase Edge Function: send-sms (Twilio). Set in Supabase Dashboard →
# Edge Functions → send-sms → Secrets, not in the Next app.
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
